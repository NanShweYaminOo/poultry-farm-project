<%@ page pageEncoding="UTF-8" %>
<header class="topbar">
  <div style="display:flex;align-items:center;gap:14px;">
    <button class="menu-toggle" aria-label="Toggle menu"><i class="bi bi-list"></i></button>
    <div class="topbar-title">
      <h1 class="i18n" data-my="${topbarTitleMy}" data-en="${topbarTitleEn}">${topbarTitleMy}</h1>
      <p class="i18n" data-my="${topbarSubMy}" data-en="${topbarSubEn}">${topbarSubMy}</p>
    </div>
  </div>
  <div class="topbar-actions">
    <div class="lang-switch">
      <button data-lang="my">MY</button>
      <button data-lang="en">EN</button>
    </div>
    <div class="admin-profile">
      <div class="avatar">?</div>
      <div>
        <div class="name">-</div>
        <div class="role i18n" data-my="ဧည့်သည်" data-en="Guest">ဧည့်သည်</div>
      </div>
    </div>
  </div>
</header>
